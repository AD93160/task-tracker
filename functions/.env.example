# Copier ce fichier en .env et renseigner les valeurs pour le développement local.
# En production : définir ces variables dans Firebase Console → Functions → Runtime Config
# ou via : firebase functions:config:set (déprécié) / Secret Manager.

EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
APP_URL=https://votre-domaine.vercel.app/?join=true
