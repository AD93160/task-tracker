rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Avatar utilisateur : lecture publique, écriture par le propriétaire
    match /users/{uid}/avatar {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Pièces jointes tâches perso : seul le propriétaire peut lire/écrire/supprimer
    match /users/{uid}/attachments/{taskId}/{fileName} {
      allow read:   if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
                    && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Pièces jointes tâches équipe : membres authentifiés peuvent lire
    // Seul le uploadeur ou un admin peut supprimer (géré côté app via pendingChanges)
    match /teams/{teamId}/attachments/{taskId}/{fileName} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null;
    }
  }
}
