rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Admin original (propriétaire, adminUid)
    function isAdminOf(teamId) {
      return isAuth() &&
             get(/databases/$(database)/documents/teams/$(teamId)).data.adminUid == request.auth.uid;
    }

    // Co-admin (promu par l'admin, uid dans coAdminUids)
    function isCoAdminOf(teamId) {
      return isAuth() &&
             get(/databases/$(database)/documents/teams/$(teamId)).data.get('coAdminUids', []).hasAny([request.auth.uid]);
    }

    // Admin OU co-admin
    function isAdminOrCoAdminOf(teamId) {
      return isAdminOf(teamId) || isCoAdminOf(teamId);
    }

    // Vérifie si l'utilisateur est membre d'une équipe via allTeamIds (supporte multi-équipes)
    function isMemberOf(teamId) {
      return isAuth() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('allTeamIds', []).hasAny([teamId]);
    }

    // Vérifie si l'utilisateur a une invitation en attente
    function hasInviteTo(teamId) {
      return isAuth() &&
             exists(/databases/$(database)/documents/invitations/$(request.auth.token.email.lower())) &&
             get(/databases/$(database)/documents/invitations/$(request.auth.token.email.lower())).data.teamId == teamId;
    }

    // Vérifie si l'utilisateur est participant d'une conversation DM
    // convId = [uid1, uid2].sort().join("_")
    function isDmParticipant(convId) {
      return isAuth() && (
        convId.matches(request.auth.uid + '_.*') ||
        convId.matches('.*_' + request.auth.uid)
      );
    }

    // ── Profils utilisateurs ──────────────────────────────────────────
    match /users/{uid} {
      // Seul l'utilisateur lui-même peut lire/créer/modifier/supprimer son profil
      allow read, create, update, delete: if isAuth() && request.auth.uid == uid;
    }

    // ── Invitations (indexées par email) ─────────────────────────────
    match /invitations/{email} {
      allow read: if isAuth() && request.auth.token.email.lower() == email;
      // Seul un admin ou co-admin de l'équipe ciblée peut créer/modifier une invitation
      allow create, update: if isAuth() && isAdminOrCoAdminOf(request.resource.data.teamId);
      allow delete: if isAuth() && request.auth.token.email.lower() == email;
    }

    // ── Équipes ───────────────────────────────────────────────────────
    match /teams/{teamId} {
      allow read: if isMemberOf(teamId) || isAdminOrCoAdminOf(teamId) ||
                     (isAuth() && resource.data.adminUid == request.auth.uid);
      allow create: if isAuth() &&
                       request.resource.data.adminUid == request.auth.uid &&
                       request.resource.data.name is string &&
                       request.resource.data.name.size() > 0 &&
                       request.resource.data.name.size() <= 50;
      // Admins/co-admins : mise à jour libre
      // Membres : uniquement pour quitter l'équipe (retirer son uid de members)
      // Invités : uniquement pour rejoindre (ajouter son uid à members)
      allow update: if isAdminOrCoAdminOf(teamId) ||
                       (isMemberOf(teamId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])) ||
                       (hasInviteTo(teamId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']));
      allow delete: if isAdminOf(teamId);

      // ── Stats membres ─────────────────────────────────────────────
      match /memberStats/{uid} {
        allow write: if isAuth() && request.auth.uid == uid;
        allow read: if isAdminOrCoAdminOf(teamId) || (isAuth() && request.auth.uid == uid);
      }

      // ── Tâches d'équipe ───────────────────────────────────────────
      match /tasks/{taskId} {
        allow read: if isMemberOf(teamId) || isAdminOrCoAdminOf(teamId);
        // Admin ET co-admins peuvent créer/modifier/supprimer directement
        allow create, update, delete: if isAdminOrCoAdminOf(teamId);
        // Membres : notification perso uniquement — les PJ passent par pendingChanges
        allow update: if isMemberOf(teamId) &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notifyUsers']);

        // ── Commentaires ─────────────────────────────────────────────
        match /comments/{commentId} {
          allow read: if isMemberOf(teamId) || isAdminOrCoAdminOf(teamId);
          allow create: if isMemberOf(teamId) || isAdminOrCoAdminOf(teamId);
          allow delete: if isAdminOrCoAdminOf(teamId) ||
                         (isAuth() && resource.data.authorUid == request.auth.uid);
          allow update: if false;
        }
      }

      // ── Corbeille équipe ─────────────────────────────────────────
      match /deletedTasks/{taskId} {
        allow read, write: if isAdminOrCoAdminOf(teamId);
      }

      // ── Messagerie instantanée ────────────────────────────────────
      match /messages/{messageId} {
        allow read: if isMemberOf(teamId) || isAdminOrCoAdminOf(teamId);
        allow create: if (isMemberOf(teamId) || isAdminOrCoAdminOf(teamId)) &&
                         request.resource.data.authorUid == request.auth.uid &&
                         request.resource.data.text is string &&
                         request.resource.data.text.size() <= 2000 &&
                         (request.resource.data.text.size() > 0 || request.resource.data.keys().hasAny(['attachment']));
        allow delete: if isAdminOrCoAdminOf(teamId) ||
                         (isAuth() && resource.data.authorUid == request.auth.uid);
        allow update: if isAuth() &&
                         resource.data.authorUid == request.auth.uid &&
                         request.resource.data.authorUid == resource.data.authorUid &&
                         request.resource.data.text is string &&
                         request.resource.data.text.size() <= 2000 &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'edited']);
      }

      // ── Messages privés (DM) ─────────────────────────────────────
      // convId = [uid1, uid2].sort().join("_") — seuls les participants peuvent lire
      match /dms/{convId}/messages/{messageId} {
        allow read: if isAdminOrCoAdminOf(teamId) || isDmParticipant(convId);
        allow create: if isDmParticipant(convId) &&
                         request.resource.data.authorUid == request.auth.uid &&
                         request.resource.data.text is string &&
                         request.resource.data.text.size() <= 2000;
        allow delete: if isAuth() && resource.data.authorUid == request.auth.uid;
        allow update: if isAuth() &&
                         resource.data.authorUid == request.auth.uid &&
                         request.resource.data.authorUid == resource.data.authorUid &&
                         request.resource.data.text is string &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'edited']);
      }

      // ── Modifications en attente ──────────────────────────────────
      match /pendingChanges/{changeId} {
        // Admin et co-admins voient tout ; les membres voient uniquement leurs propres propositions
        allow read: if isAdminOrCoAdminOf(teamId) ||
                       (isMemberOf(teamId) && resource.data.proposedBy == request.auth.uid);
        allow create: if isMemberOf(teamId) || isAdminOrCoAdminOf(teamId);
        allow delete: if isAdminOrCoAdminOf(teamId);
        allow update: if false;
      }
    }

  }
}
